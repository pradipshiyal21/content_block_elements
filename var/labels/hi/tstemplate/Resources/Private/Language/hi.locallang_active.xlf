<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" version="1.2">
  <file source-language="en" datatype="plaintext" original="EXT:tstemplate/Resources/Private/Language/locallang_active.xlf" date="2011-10-17T20:22:37Z" product-name="tstemplate" target-language="hi">
    <header/>
    <body>
      <trans-unit id="submodule.title" approved="yes">
        <source>Active TypoScript</source>
        <target state="final">सक्रिय TypoScript</target>
      </trans-unit>
      <trans-unit id="submodule.titleWithRecord" approved="yes">
        <source>Active TypoScript for record "%s"</source>
        <target state="final">रिकॉर्ड "%s" के लिए सक्रिय TypoScript</target>
      </trans-unit>
      <trans-unit id="submodule.description" approved="yes">
        <source>Overview of the current TypoScript configuration of the system, divided into constants and setup parts. Optionally, the constant values can be displayed directly in the setup. A targeted search for values and TypoScript names is possible. The list of results can also be filtered according to TypoScript conditions.</source>
        <target state="final">सिस्टम के वर्तमान TypoScript कॉन्फ़िगरेशन का अवलोकन, स्थिरांकों और सेटअप भागों में विभाजित। वैकल्पिक रूप से, स्थिरांक मान सीधे सेटअप में प्रदर्शित किए जा सकते हैं। मानों और TypoScript नामों के लिए लक्षित खोज संभव है। परिणामों की सूची को TypoScript शर्तों के अनुसार भी फ़िल्टर किया जा सकता है।</target>
      </trans-unit>
      <trans-unit id="infobox.message.noTypoScriptFound" approved="yes">
        <source>No TypoScript found.</source>
        <target state="final">कोई TypoScript नहीं मिली।</target>
      </trans-unit>
      <trans-unit id="options.displayComments" approved="yes">
        <source>Display comments</source>
        <target state="final">टिप्पणियाँ प्रदर्शित करें</target>
      </trans-unit>
      <trans-unit id="options.displayConstantSubstitutions" approved="yes">
        <source>Substitute constants in setup</source>
        <target state="final">सेटअप में कॉन्स्टेंट्स प्रतिस्थापित करें</target>
      </trans-unit>
      <trans-unit id="options.selectedRecord" approved="yes">
        <source>Selected record</source>
        <target state="final">चयनित रिकॉर्ड</target>
      </trans-unit>
      <trans-unit id="options.sortAlphabetically" approved="yes">
        <source>Sort keys alphabetically</source>
        <target state="final">टाइपोस्क्रिप्ट उपकरणकुंजियों को वर्णानुक्रम में क्रमबद्ध करें</target>
      </trans-unit>
      <trans-unit id="sectionHeadline.constants" approved="yes">
        <source>Constants</source>
        <target state="final">स्थिरांक</target>
      </trans-unit>
      <trans-unit id="sectionHeadline.setup" approved="yes">
        <source>Setup</source>
        <target state="final">सेटअप</target>
      </trans-unit>
      <trans-unit id="panel.header.conditions" approved="yes">
        <source>Conditions</source>
        <target state="final">शर्तें</target>
      </trans-unit>
      <trans-unit id="panel.header.configuration" approved="yes">
        <source>Configuration</source>
        <target state="final">कॉन्फ़िगरेशन</target>
      </trans-unit>
      <trans-unit id="panel.header.numberOfSearchMatches" approved="yes">
        <source>%s search match(es)</source>
        <target state="final">%s खोज मिलान (ओं)</target>
      </trans-unit>
      <trans-unit id="panel.info.conditionActiveCount.multiple" approved="yes">
        <source>%s active conditions</source>
        <target state="final">%s सक्रिय शर्तें</target>
      </trans-unit>
      <trans-unit id="panel.info.conditionActiveCount.single" approved="yes">
        <source>%s active condition</source>
        <target state="final">%s सक्रिय शर्त</target>
      </trans-unit>
      <trans-unit id="panel.info.conditionWithConstant" approved="yes">
        <source>Constant usage: [%s]</source>
        <target state="final">स्थिर उपयोग: [%s]</target>
      </trans-unit>
      <trans-unit id="tree.valueWithConstant" approved="yes">
        <source>Constant usage: %s</source>
        <target state="final">स्थिर उपयोग: %s</target>
      </trans-unit>
      <!-- Edit action -->
      <trans-unit id="editAction.submodule.title" approved="yes">
        <source>Edit single property</source>
        <target state="final">एकल संपत्ति संपादित करें</target>
      </trans-unit>
      <trans-unit id="editAction.submodule.titleWithTemplate" approved="yes">
        <source>Edit single property in TypoScript record "%s"</source>
        <target state="final">TypoScript रिकॉर्ड "%s" में एकल संपत्ति संपादित करें</target>
      </trans-unit>
      <trans-unit id="editAction.infobox.title.noTypoScriptTemplateOnCurrentPage" approved="yes">
        <source>No TypoScript record on the current page</source>
        <target state="final">वर्तमान पृष्ठ पर कोई TypoScript रिकॉर्ड नहीं</target>
      </trans-unit>
      <trans-unit id="editAction.infobox.message.noTypoScriptTemplateOnCurrentPage" approved="yes">
        <source>You cannot edit properties and values if there is no current TypoScript record in which the configuration can be stored. Please create an extension TypoScript record in "Edit TypoScript Record" first.</source>
        <target state="final">यदि कॉन्फ़िगरेशन संग्रहीत कर सकने वाला कोई वर्तमान TypoScript रिकॉर्ड नहीं है तो आप संपत्तियों और मानों को संपादित नहीं कर सकते। कृपया "TypoScript रिकॉर्ड संपादित करें" में एक एक्सटेंशन TypoScript रिकॉर्ड बनाएं।</target>
      </trans-unit>
      <trans-unit id="editAction.addProperty.headline" approved="yes">
        <source>Add or override child property</source>
        <target state="final">चाइल्ड प्रॉपर्टी जोड़ें या ओवरराइड करें</target>
      </trans-unit>
      <trans-unit id="editAction.addProperty.btn" approved="yes">
        <source>Add</source>
        <target state="final">जोड़ें</target>
      </trans-unit>
      <trans-unit id="editAction.editProperty.headline" approved="yes">
        <source>Edit current value</source>
        <target state="final">वर्तमान मान संपादित करें</target>
      </trans-unit>
      <trans-unit id="editAction.editProperty.btn" approved="yes">
        <source>Update</source>
        <target state="final">अपडेट करें</target>
      </trans-unit>
      <trans-unit id="editAction.clearObject.headline" approved="yes">
        <source>Clear the object</source>
        <target state="final">ऑब्जेक्ट को साफ़ करें</target>
      </trans-unit>
      <trans-unit id="editAction.clearObject.infotextWithProperty" approved="yes">
        <source>The object will be cleared via the statement:</source>
        <target state="final">यह वक्तव्य द्वारा ऑब्जेक्ट को साफ़ किया जाएगा:</target>
      </trans-unit>
      <trans-unit id="editAction.clearObject.btn" approved="yes">
        <source>Clear now</source>
        <target state="final">अब साफ़ करें</target>
      </trans-unit>
      <!-- Update action -->
      <trans-unit id="updateAction.lineAdded" approved="yes">
        <source>Line added to current TypoScript record</source>
        <target state="final">वर्तमान TypoScript रिकॉर्ड में लाइन जोड़ी गई</target>
      </trans-unit>
      <trans-unit id="updateAction.lineNotAdded" approved="yes">
        <source>No line added to current TypoScript record</source>
        <target state="final">वर्तमान TypoScript रिकॉर्ड में कोई लाइन जोड़ी नहीं गई</target>
      </trans-unit>
      <trans-unit id="updateAction.noSpaces" approved="yes">
        <source>You must enter a property with characters "a-z", "A-Z", "0-9", or ".". Dots will be quoted. No spaces or special chars.</source>
        <target state="final">आपको वर्ण "a-z", "A-Z", "0-9", या "." वाली संपत्ति दर्ज करनी होगी। बिंदु उद्धृत होंगे। कोई रिक्त स्थान या विशेष चरित्र नहीं।</target>
      </trans-unit>
    </body>
  </file>
</xliff>
