<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" version="1.2">
  <file source-language="en" datatype="plaintext" original="EXT:reactions/Resources/Private/Language/locallang_db.xlf" date="2022-08-15T20:22:32Z" product-name="reactions" target-language="hi">
    <header/>
    <body>
      <trans-unit id="reactions" approved="yes">
        <source>Reactions</source>
        <target state="final">प्रतिक्रियाएँ</target>
      </trans-unit>
      <trans-unit id="sys_reaction" approved="yes">
        <source>System Reactions</source>
        <target state="final">सिस्टम की प्रतिक्रियाएँ</target>
      </trans-unit>
      <trans-unit id="sys_reaction.name" approved="yes">
        <source>Name</source>
        <target state="final">नाम</target>
      </trans-unit>
      <trans-unit id="sys_reaction.name.description" approved="yes">
        <source>Meaningful name of the reaction</source>
        <target state="final">प्रतिक्रिया का मार्गदर्शक नाम</target>
      </trans-unit>
      <trans-unit id="sys_reaction.identifier" approved="yes">
        <source>Identifier</source>
        <target state="final">पहचानकर्ता</target>
      </trans-unit>
      <trans-unit id="sys_reaction.identifier.description" approved="yes">
        <source>This is your unique reaction identifier within the TYPO3 URL</source>
        <target state="final">यह आपकी अद्वितीय प्रतिक्रिया पहचानकर्ता है जो TYPO3 URL के अंदर है</target>
      </trans-unit>
      <trans-unit id="sys_reaction.secret" approved="yes">
        <source>Secret</source>
        <target state="final">गुप्त</target>
      </trans-unit>
      <trans-unit id="sys_reaction.secret.description" approved="yes">
        <source>The secret is required to call the reaction from the outside. The secret can be re-created anytime, but will only be visible once (until the record got saved).</source>
        <target state="final">प्रतिक्रिया को बाहर से बुलाने के लिए गुप्त की आवश्यकता होती है। गुप्त को कभी भी फिर से उत्पन्न किया जा सकता है, लेकिन यह केवल एक बार दिखाई देगा (जब तक रिकॉर्ड सहेजा नहीं गया हो)।</target>
      </trans-unit>
      <trans-unit id="sys_reaction.secret.passwordGenerator" approved="yes">
        <source>Generate secret token</source>
        <target state="final">गुप्त टोकन उत्पन्न करें</target>
      </trans-unit>
      <trans-unit id="sys_reaction.reaction_type" approved="yes">
        <source>Reaction Type</source>
        <target state="final">प्रतिक्रिया प्रकार</target>
      </trans-unit>
      <trans-unit id="sys_reactions.reaction_type.description" approved="yes">
        <source>Select the reaction type to be configured.</source>
        <target state="final">विन्यासित होने वाले प्रतिक्रिया प्रकार का चयन करें।</target>
      </trans-unit>
      <trans-unit id="sys_reaction.reaction_type.select" approved="yes">
        <source>Select a reaction</source>
        <target state="final">प्रतिक्रिया का चयन करें</target>
      </trans-unit>
      <trans-unit id="sys_reaction.reaction_type.create_record" approved="yes">
        <source>Create database record</source>
        <target state="final">डेटाबेस रिकॉर्ड बनाएं</target>
      </trans-unit>
      <trans-unit id="sys_reaction.impersonate_user" approved="yes">
        <source>Impersonate User</source>
        <target state="final">उपयोगकर्ता का अनुकरण करें</target>
      </trans-unit>
      <trans-unit id="sys_reaction.impersonate_user.description" approved="yes">
        <source>Select the user with the appropriate access rights that is allowed to add a record of this type. If in doubt, use the CLI user.</source>
        <target state="final">ऐसे उपयोगकर्ता का चयन करें जिसे इस प्रकार के रिकॉर्ड को जोड़ने का उपयुक्त अधिकार हो। यदि संदेह हो, तो CLI उपयोगकर्ता का उपयोग करें।</target>
      </trans-unit>
      <trans-unit id="sys_reaction.table_name" approved="yes">
        <source>Table</source>
        <target state="final">टेबल</target>
      </trans-unit>
      <trans-unit id="sys_reaction.table_name.description" approved="yes">
        <source>Select one tables to display the corresponding fields.</source>
        <target state="final">एक टेबल का चयन करें जिससे संबंधित फ़ील्ड्स प्रदर्शित किए जाएं।</target>
      </trans-unit>
      <trans-unit id="sys_reaction.table_name.select" approved="yes">
        <source>Select a table</source>
        <target state="final">एक टेबल चुनें</target>
      </trans-unit>
      <trans-unit id="sys_reaction.storage_pid" approved="yes">
        <source>Storage PID</source>
        <target state="final">संग्रहण PID</target>
      </trans-unit>
      <trans-unit id="sys_reaction.storage_pid.description" approved="yes">
        <source>Select the page on which a new record is created on.</source>
        <target state="final">ऐसे पृष्ठ का चयन करें जिसपर एक नया रिकॉर्ड बनाया जाता है।</target>
      </trans-unit>
      <trans-unit id="sys_reaction.fields" approved="yes">
        <source>Fields</source>
        <target state="final">फ़ील्ड्स</target>
      </trans-unit>
      <trans-unit id="sys_reaction.fields.description" approved="yes">
        <source>The available fields depend on the selected table. The usage of placeholders like ${foo.bar} is possible.</source>
        <target state="final">उपलब्ध फ़ील्ड्स चयनित तालिका पर निर्भर करते हैं। ${foo.bar} जैसे स्थानधारक का उपयोग संभव है।</target>
      </trans-unit>
      <trans-unit id="palette.config" approved="yes">
        <source>Configuration</source>
        <target state="final">कॉन्फ़िगरेशन</target>
      </trans-unit>
      <trans-unit id="palette.config.description" approved="yes">
        <source>General configuration of the reaction.</source>
        <target state="final">प्रतिक्रिया का सामान्य विन्यास।</target>
      </trans-unit>
      <trans-unit id="palette.additional" approved="yes">
        <source>Additional configuration</source>
        <target state="final">अतिरिक्त विन्यास</target>
      </trans-unit>
      <trans-unit id="palette.additional.description" approved="yes">
        <source>Specific configuration for the selected reaction type</source>
        <target state="final">चयनित प्रतिक्रिया प्रकार के लिए विशिष्ट विन्यास</target>
      </trans-unit>
      <trans-unit id="fieldMapElement.noFields" approved="yes">
        <source>The selected table '%s' does not define any valid fields to be configured.</source>
        <target state="final">चयनित तालिका '%s' किसी भी मान्य फ़ील्ड्स को विन्यासित करने के लिए निर्धारित नहीं करती है।</target>
      </trans-unit>
    </body>
  </file>
</xliff>
